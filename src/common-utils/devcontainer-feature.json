{
  "name": "Common Utilities",
  "id": "common-utils",
  "version": "1.0.0",
  "description": "Installs common command line utilities, Oh My Zsh!, and sets up a non-root user. Includes GNU/POSIX utilities and glibc locale support for Wolfi-based containers.",
  "documentationURL": "https://github.com/xorpse/devcontainer-features/tree/master/src/common-utils",
  "options": {
    "installZsh": {
      "type": "boolean",
      "default": true,
      "description": "Install zsh"
    },
    "configureZshAsDefaultShell": {
      "type": "boolean",
      "default": false,
      "description": "Configure zsh as the default shell for the user"
    },
    "installOhMyZsh": {
      "type": "boolean",
      "default": true,
      "description": "Install Oh My Zsh!"
    },
    "installOhMyZshConfig": {
      "type": "boolean",
      "default": true,
      "description": "Install the default Oh My Zsh! configuration (template .zshrc)"
    },
    "upgradePackages": {
      "type": "boolean",
      "default": true,
      "description": "Upgrade existing packages"
    },
    "username": {
      "type": "string",
      "proposals": [
        "devcontainer",
        "vscode",
        "codespace",
        "none",
        "automatic"
      ],
      "default": "automatic",
      "description": "Username for the non-root user"
    },
    "userUid": {
      "type": "string",
      "proposals": [
        "1001",
        "automatic"
      ],
      "default": "automatic",
      "description": "UID for the non-root user"
    },
    "userGid": {
      "type": "string",
      "proposals": [
        "1001",
        "automatic"
      ],
      "default": "automatic",
      "description": "GID for the non-root user"
    },
    "sudo": {
      "type": "boolean",
      "default": true,
      "description": "Grant the user passwordless sudo access"
    },
    "installSsl": {
      "type": "boolean",
      "default": true,
      "description": "Install OpenSSL libraries"
    }
  },
  "installsAfter": [
    "ghcr.io/xorpse/devcontainer-features/user",
    "ghcr.io/xorpse/devcontainer-features/bash"
  ]
}
